{
  "info": {
    "name": "Pruebas Seguridad ms-usuarios",
    "description": "Colección para probar la seguridad y JWT del microservicio ms-usuarios.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Login Admin (Generar Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.token) {",
              "    pm.collectionVariables.set(\"admin_token\", jsonData.token);",
              "    console.log(\"Token Admin guardado correctamente.\");",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "http://localhost:9001/api/auth/login",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "9001",
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "2. Login Cliente (Generar Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.token) {",
              "    pm.collectionVariables.set(\"cliente_token\", jsonData.token);",
              "    console.log(\"Token Cliente guardado correctamente.\");",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"cliente@test.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "http://localhost:9001/api/auth/login",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "9001",
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "3. Listar Usuarios (Como ADMIN - Debe Funcionar)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": {
          "raw": "http://localhost:9001/api/usuarios",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "9001",
          "path": [
            "api",
            "usuarios"
          ]
        }
      }
    },
    {
      "name": "4. Listar Usuarios (Como CLIENTE - Debe dar Error 403)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{cliente_token}}"
          }
        ],
        "url": {
          "raw": "http://localhost:9001/api/usuarios",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "9001",
          "path": [
            "api",
            "usuarios"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "admin_token",
      "value": ""
    },
    {
      "key": "cliente_token",
      "value": ""
    }
  ]
}
